source 'https://github.com/CocoaPods/Specs'


def thridparty
    pod 'SSZipArchive', '~> 2.1'
    # pod 'SSZipArchive', :git => 'https://github.com/ZipArchive/ZipArchive', :commit => '81d8deeaf0d19f6e3ac40f55e5f9f3cdf1b433a3'
end

target 'XlsxReaderWriter' do
    platform :ios, '9.0'
    thridparty
    use_frameworks!
end

target 'XlsxReaderWriter-iOS' do
    platform :ios, '9.0'
    thridparty
    use_frameworks!
end

target 'XlsxReaderWriterTests' do
    platform :ios, '9.0'
    thridparty
	use_frameworks!
end
